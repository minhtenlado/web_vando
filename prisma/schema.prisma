// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CMS models for the CV site (editable from /admin) ---

// Profile row per locale (id = "profile-vi" / "profile-en").
model Profile {
  id        String   @id @default("profile")
  locale    String   @default("vi")
  name      String   @default("Phan Huỳnh Văn Đô")
  role      String   @default("Embedded Software Engineer")
  tagline   String   @default("Lập trình viên nhúng · RTOS · ARM Cortex · IoT")
  location  String   @default("TP. Hồ Chí Minh, Việt Nam")
  email     String   @default("minhanh.embedded@gmail.com")
  phone     String   @default("+84 912 345 678")
  website   String   @default("minhanh-embedded.dev")
  github    String   @default("github.com/minhanh-embedded")
  linkedin  String   @default("linkedin.com/in/minhanh-embedded")
  summary   String   @default("")
  avatar    String   @default("/uploads/avatar.jpg")
  principles String  @default("[]") // JSON string of { icon, title, desc }
  stats      String  @default("[]") // JSON string of { value, label }
  nowText    String  @default("")
  skillGroups String @default("[]") // JSON string of { title, icon, skills }
  socials    String  @default("[]") // JSON string of { platform, url, enabled }
  aboutSubtitle      String @default("")
  skillsSubtitle     String @default("")
  experienceSubtitle String @default("")
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  locale      String   @default("vi")
  title       String
  category    String   @default("")
  description String   @default("")
  // JSON-encoded string[] for SQLite (no native array type)
  features    String   @default("[]")
  tech        String   @default("[]")
  image       String   @default("")
  images      String   @default("[]") // JSON string[] gallery
  youtubeUrl  String?  // optional YouTube watch/embed URL
  link        String?
  repo        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  locale    String   @default("vi")
  title     String
  slug      String
  excerpt   String   @default("")
  content   String   @default("") // markdown
  published Boolean  @default(true)
  seoTitle  String?
  seoDescription String?
  seoKeywords String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
}

model Experience {
  id          String   @id @default(cuid())
  locale      String   @default("vi")
  role        String
  company     String
  companyUrl  String?  // link to company website
  period      String
  location    String   @default("")
  description String   @default("")
  highlights  String   @default("[]") // JSON string[]
  stack       String   @default("[]") // JSON string[]
  images      String   @default("[]") // JSON string[] gallery
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
